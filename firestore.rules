rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'backend-system' ||
        request.auth.uid == 'backend-admin' ||
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'system' ||
        (request.auth.token.email != null && request.auth.token.email in [
          'tupass@gmail.com',
          'tupamobilidade@gmail.com',
          'xofometupa@gmail.com',
          'ifood.clara@gmail.com',
          'ifoodclara@gmail.com',
          'admin@gestao.com',
          'suporte@tupa.com'
        ]) ||
        request.auth.uid in [
          'backend-system',
          'backend-admin',
          'franksonxofome',
          'adZ8V1w2bnVm2atLYqsVdiCqNzD3',
          'system-monitor',
          'service-account-splitter'
        ]
      );
    }

    function isBranchManager(branchId) {
      return isSignedIn() && branchId != null && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId == branchId)
      );
    }

    function isRestaurantOwner(restaurantId) {
      return isSignedIn() && (
        isAdmin() || (
          exists(/databases/$(database)/documents/restaurants/$(restaurantId)) && (
            get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerUid == request.auth.uid ||
            (get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.employees != null &&
             request.auth.uid in get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.employees) ||
            (get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.branchId != null && 
             isBranchManager(get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.branchId))
          )
        )
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidString(val, max) {
      return val is string && val.size() <= max;
    }

    // --- DEFAULT DENY ---
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- COLLECTIONS ---

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) || isAdmin()) && (
        isAdmin() || (
          // Standard users cannot change their own roles or critical stats directly
          incoming().diff(existing()).affectedKeys().hasOnly([
            'displayName', 'phone', 'photoUrl', 'address', 'theme', 'vehicleType', 
            'vehiclePlate', 'vehicleColor', 'whatsapp', 'cpf', 'branchId', 'cityId', 
            'isGuest', 'location', 'lastActive', 'lastLogin', 'fcmToken',
            'notificationSettings', 'isOnline', 'lastLatitude', 'lastLongitude', 'lastCity', 'lastAddress',
            'latitude', 'longitude', 'city', 'status', 'configuracoesDeNotificacao', 'está online',
            'locationUpdatedAt', 'updatedAt', 'lastUpdate', 'pushToken', 'oneSignalId'
          ])
        )
      );
    }

    match /restaurants/{restaurantId} {
      allow read: if true;
      allow create: if (isSignedIn()) && isValidId(restaurantId);
      allow update: if (isRestaurantOwner(restaurantId) || isAdmin()) && (
        isAdmin() || (
           // Protect fields like ownerUid and mod during update
           incoming().ownerUid == existing().ownerUid &&
           incoming().diff(existing()).affectedKeys().hasAny(['status', 'description', 'imageUrl', 'logoUrl', 'openingHours', 'closingHours', 'weeklyHours', 'activityExpiresAt', 'forceClosed', 'acceptedPaymentMethods', 'autoVolume', 'screenOverlay', 'pixKey', 'pixType', 'pixConfigType', 'likesCount'])
        )
      );
    }

    match /food_items/{itemId} {
      allow read: if true;
      allow create: if isRestaurantOwner(incoming().restaurantId) || isAdmin();
      allow update: if isRestaurantOwner(existing().restaurantId) || isAdmin();
      allow delete: if isRestaurantOwner(existing().restaurantId) || isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        isOwner(existing().customerUid) || 
        isRestaurantOwner(existing().restaurantId) || 
        isOwner(existing().courierUid) || 
        isAdmin() ||
        (isSignedIn() && resource.data.branchId != null && resource.data.branchId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId)
      );
      allow create: if isSignedIn() && (isOwner(incoming().customerUid) || isAdmin());
      allow update: if isSignedIn() && (
        isAdmin() ||
        isRestaurantOwner(existing().restaurantId) ||
        isOwner(existing().courierUid) ||
        (existing().branchId != null && isBranchManager(existing().branchId)) ||
        (isOwner(existing().customerUid) && incoming().status == 'cancelled')
      );
      
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /wallets/{uid} {
      allow read: if isOwner(uid) || isAdmin() || 
        (isSignedIn() && (
          (exists(/databases/$(database)/documents/wallets/$(uid)) && get(/databases/$(database)/documents/wallets/$(uid)).data.ownerUid == request.auth.uid) ||
          (resource.data.branchId != null && 
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           resource.data.branchId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId)
        ));
      allow list: if isAdmin() || (isSignedIn() && resource.data.ownerUid == request.auth.uid);
      allow create: if isOwner(uid) || isAdmin();
      allow update: if isAdmin();
    }
    
    match /wallet_transactions/{txId} {
      allow read: if isSignedIn() && (isOwner(existing().ownerUid) || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /category_schedules/{scheduleId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /promotional_banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /marketing_popups/{popupId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /admin_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    match /cpfs/{cpf} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /rides/{rideId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /splitpay_history/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /pix_payments/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /payments/{id} {
      allow read: if isAdmin() || (isSignedIn() && isOwner(existing().customerUid));
      allow create: if isSignedIn();
    }

    match /branches/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /business_categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /likes/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /reviews/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isOwner(existing().customerUid);
    }

    match /table_actions/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /printers/{id} {
      allow read, write: if isRestaurantOwner(incoming().restaurantId || existing().restaurantId) || isAdmin();
    }
    
    match /push_notifications/{id} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
    }

    match /page_views/{id} {
      allow create: if true;
      allow read: if isAdmin();
    }
  }
}
